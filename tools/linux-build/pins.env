# pins.env — Phase 85A spike toolchain SHA256 pin manifest
#
# First-download date: 2026-05-26
#
# Provenance:
#   - RESEARCH.md §Package Legitimacy Audit (lines 109-136) — disposition rationale
#     for raw GitHub .sh assets that slopcheck does not cover.
#   - RESEARCH.md §Common Pitfalls / Pitfall 8 (lines 371-381) — linuxdeploy-plugin-gstreamer
#     maintenance dormancy; SHA256 pin is the supply-chain mitigation.
#   - First-download SHA256 captured per system-prompt §package legitimacy gate.
#     npm/pip/cargo policy does not cover raw GitHub `.sh` assets, so this
#     SHA256-pin-at-first-download is the project-specific equivalent.
#
# Sourceable shell KEY=VALUE format (no spaces around =, no quotes around hex).
# Consumed by:
#   - verify-pins.sh (drift-guard; same dir)
#   - tools/linux-build/build.sh (Phase 85)
#
# To re-verify pins still match upstream: bash verify-pins.sh
# (exit 0 = match, exit 2 = drift detected)

LINUXDEPLOY_URL=https://github.com/linuxdeploy/linuxdeploy/releases/download/continuous/linuxdeploy-x86_64.AppImage
LINUXDEPLOY_SHA256=f2aa8e8bb6265d0edc0b0c666c494dc8975650af589408748d75c9b99434b570
LINUXDEPLOY_PLUGIN_CONDA_URL=https://raw.githubusercontent.com/linuxdeploy/linuxdeploy-plugin-conda/master/linuxdeploy-plugin-conda.sh
LINUXDEPLOY_PLUGIN_CONDA_SHA256=00ab1cb015ec7d97c8278a285fa5025b49c6bf3de1bc0bcf62ec38cfb6e1544a
LINUXDEPLOY_PLUGIN_GSTREAMER_URL=https://raw.githubusercontent.com/linuxdeploy/linuxdeploy-plugin-gstreamer/master/linuxdeploy-plugin-gstreamer.sh
LINUXDEPLOY_PLUGIN_GSTREAMER_SHA256=c107b49d84edbffc6ab226ed1007e0626a4f7aa2c3a36b7782bef62351d49e94
MINICONDA_VERSION=py312_24.9.2-0

# Miniforge3 swap (Pitfall 13 mitigation): Miniconda3-latest ships with
# Anaconda's `defaults` channels (pkgs/main + pkgs/r) in its base condarc,
# and conda 24.x's ToS gate trips on channel PRESENCE (not use) — so
# CONDA_CHANNELS=conda-forge does NOT neutralize it. Miniforge3 ships
# with conda-forge only, no ToS. Phase 43 Windows spike used Miniforge.
# Pinning the versioned tag (not "latest" symlink) for drift-friendliness.
MINIFORGE_TAG=26.3.2-2
MINIFORGE_URL=https://github.com/conda-forge/miniforge/releases/download/26.3.2-2/Miniforge3-26.3.2-2-Linux-x86_64.sh
MINIFORGE_SHA256=42260ffe3830fb953d5eee1bbb32229ff06aa7c3833c1ed7a9a0420a95685d94

# Pitfall 13b: plugin-conda hardcodes the Miniconda3 URL (lines 107, 122
# of the pinned upstream). The CONDA_DOWNLOAD_DIR override the plugin
# advertises is defeated by its own `touch -d '@0'` + `wget -N` (line 125).
# Approach P: deterministic sed patch swaps the URL to Miniforge3. The
# patched-script SHA256 below is captured for audit; build.sh re-derives
# it from upstream + the documented sed transformation.
LINUXDEPLOY_PLUGIN_CONDA_PATCHED_SHA256=49bf6cddfc2b9c2f70bd80b22ba030621c19532f2bd7df26a40bf624afdbdc26
