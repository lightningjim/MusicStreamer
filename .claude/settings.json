{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gsd-sdk query commit *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/bump-version-hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
